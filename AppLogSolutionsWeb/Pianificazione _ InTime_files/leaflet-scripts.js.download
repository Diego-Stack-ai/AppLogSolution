const PANEL_PAGE_SIZE = 10;
var map;
var currentFeatureGroup;
var driverMap;
var truckMarker;
var monitoringMap;
var geoFencingMap;
var itinerariesMap;
var trucksMap;
var lon = 12.469;
var lat = 41.894;
var defaultPoint = {
	lat: 44.70,
	lon: 10.63
};
var defaultZoom = 7;
var lapLayers = new Map();
var scrollContainer;
var scrollTop;
var blockUIObserver = null;
let totalFiles = 0;
let uploadedFiles = 0;
const SUBTRIP_COLORS = [
    '#0554A6', // blu
    '#D9534F', // rosso
    '#5CB85C', // verde
    '#F0AD4E', // arancione
    '#9B59B6', // viola
    '#17A2B8', // ciano
    '#E83E8C', // rosa
    '#6C757D'  // grigio
];

function addLastLocation(latitude, longitude, code) {
	truckMarker = L.marker([latitude, longitude], {
		icon: L.icon({
			iconUrl: 'images/truck.png',
			iconSize: [34, 28]
		}),
		title: code
	}).addTo(map);
}

function initMarker(md, markerArray, index, color) {
	var isSelected = md.selected;
	const icon = new L.DivIcon({
		className: 'icon-div',
		html: `<div style="background-color: #` + (isSelected ? `001F3F !important; border-color: #943A19` : color) + ` !important; color: white !important; text-align: center; vertical-align: middle; border-style: solid; border-width: 1px; border-radius: 100px; font-size: ` + (isSelected ? 20 : 10) + `px;">` + md.index + `</div>`,
		iconSize: [isSelected ? 34 : 17, isSelected ? 34 : 17]
	});
	markerArray[index] = L
		.marker([md.latitude, md.longitude]).setIcon(icon).setZIndexOffset(isSelected ? 1000 : 100).bindTooltip(md.name, {
			className: 'leaflet-tooltip'
		}).addTo(map);
	markerArray[index].on('click', L.bind(onPlantSelect, null, md.rowId));
}

function makeRestrictionsLayer(style, apiKey, mapAttr, opacity, size) {
	size = size || 256;
	var url = 'https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/png?size=' + size + '&style=' + style
			+ '&features=vehicle_restrictions:active_and_inactive&apiKey=' + apiKey;
	return L.tileLayer(url, {
		maxZoom: 18,
		pane: 'restrictionsPane',
		tileSize: 256,
		opacity: (opacity != null ? opacity : 1),
		attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	});
}

function refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, restrictions) {
	restrictionsProxy.clearLayers();
	if (!restrictionsOn) return;
	restrictionsProxy.addLayer(restrictions);
}

function groupByLap(markersDetail) {
	const laps = new Map();
	markersDetail.forEach((md, i) => {
		const lap = md.tmpNbLap;
		if (lap != null) {
			if (!laps.has(lap)) {
				laps.set(lap, []);
			}
			laps.get(lap).push(i);
		}
	});
	return laps;
}

function getLapColor(lap) {
	const idx = Math.max(0, lap - 1);
	return SUBTRIP_COLORS[idx % SUBTRIP_COLORS.length];
}

function mapWaypointsToPolyline(markersDetail, coords) {
	var result = [];
	var startFrom = 0;
	var THRESHOLD_SQ = 1e-6;
	for (var i = 0; i < markersDetail.length; i++) {
		var md = markersDetail[i];
		var foundIdx = -1;
		var bestDist = Infinity, bestIdx = startFrom;
		for (var j = startFrom; j < coords.length; j++) {
			const dLat = coords[j][0] - md.latitude;
			const dLon = coords[j][1] - md.longitude;
			var d = dLat * dLat + dLon * dLon;
			if (d < bestDist) {
				bestDist = d;
				bestIdx = j;
			}
			if (d < THRESHOLD_SQ) {
				foundIdx = j;
				break;
			}
		}
		result[i] = foundIdx !== -1 ? foundIdx : bestIdx;
		startFrom = result[i];
	}
	return result;
}

function toggleLapVisibility(lap, visible) {
	var layers = lapLayers.get(lap);
	if (!layers) return;
	layers.markers.forEach(m => {
		if (visible) {
			m.addTo(map);
		} else {
			map.removeLayer(m);
		}
	});
	layers.polylines.forEach(p => {
		if (visible) {
			p.addTo(map);
		} else {
			map.removeLayer(p);
		}
	});
}

function addSubtripsLegend(laps, markersDetail) {
	var legend = L.control({ position: 'bottomleft' });
	legend.onAdd = function () {
		var container = L.DomUtil.create('div', 'leaflet-bar subtrips-legend-container');
		container.style.cssText = 'background: white; cursor: pointer; overflow: hidden;';
		L.DomEvent.disableClickPropagation(container);
		L.DomEvent.disableScrollPropagation(container);
		var collapsed = L.DomUtil.create('div', 'subtrips-legend-collapsed', container);
		collapsed.style.cssText = 'width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; font-size: 16px;';
		collapsed.innerHTML = '🚚';
		collapsed.title = 'Viaggi';
		var expanded = L.DomUtil.create('div', 'subtrips-legend-expanded', container);
		expanded.style.cssText = 'padding: 8px; 10px; font-size: 12px; line-height: 1.6; display: none;';
		var html = '<strong>Viaggi</strong><br>';
		var sortedLaps = Array.from(laps.entries()).sort((a, b) => a[0] - b[0]);
		sortedLaps.forEach(([lap, indices]) => {
			var color = getLapColor(lap);
			var count = indices.filter(idx => markersDetail[idx].type != null).length;
			html += `<div style="display: flex; align-items: center; gap: 6px;">
				<input type="checkbox" class="lap-toggle" data-lap="${lap}" checked style="margin: 0; cursor: pointer;" />
				<span style="display: inline-block; width: 14px; height: 14px; background: ${color}; border-radius: 2px; vertical-align: middle;"></span>
				<span>Viaggio ${lap} (${count} tappe)</span></div>`;
		});
		expanded.innerHTML = html;
		container.addEventListener('mouseenter', function () {
			collapsed.style.display = 'none';
			expanded.style.display = 'block';
		});
		container.addEventListener('mouseleave', function () {
			expanded.style.display = 'none';
			collapsed.style.display = 'flex';
		});
		expanded.querySelectorAll('.lap-toggle').forEach(cb => {
			cb.addEventListener('change', function () {
				var lap = parseInt(this.dataset.lap, 10);
				toggleLapVisibility(lap, this.checked);
			});
		});
		return container;
	};
	legend.addTo(map);
}

function initResponseDetailMapLeaflet(mapUrl, apiKey, mapAttr, route, routePolyline) {
	try {
		map.remove();
	} catch (Exception) {
	}
	var normalLayer = L.tileLayer(mapUrl + apiKey, {
		maxZoom: 18,
		attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	});
	var satelliteLayer = L.tileLayer(
		'https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/jpeg?size=256&style=explore.satellite.day&apiKey=' + apiKey, {
			maxZoom: 18,
		    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
		}
	);
	map = L.map('itineraryMapDiv', {
	    layers: [normalLayer],
	    zoomControl: true
	});
	map.createPane('restrictionsPane');
	var restrictionsDay = makeRestrictionsLayer('explore.day', apiKey, mapAttr);
	var restrictionsSat = makeRestrictionsLayer('explore.satellite.day', apiKey, mapAttr);
	map.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsProxy = L.layerGroup();
	var currentBase = 'day';
	var restrictionsOn = false;
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy
	};
	L.control.layers(baseMaps, overlays, { position: 'topright' }).addTo(map);
	map.on('baselayerchange', function (e) {
		currentBase = (e.name === 'Normale') ? 'day' : 'sat';
		refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase);
	})
	map.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = true;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, restrictionsLayer);
		}
	});
	map.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = false;
			refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, restrictionsLayer);
	    }
	});
	if (route == null || route.length < 3) {
		map.setView(defaultPoint, defaultZoom);
	}
	var markersDetail = JSON.parse(route);
	var markerArray = [];
	var waypointArray = [];
	var laps = groupByLap(markersDetail);
	lapLayers.clear();
	laps.forEach((_, lap) => lapLayers.set(lap, { markers: [], polylines: [] }));
	for (var index = 0; index < markersDetail.length; index++) {
	    var md = markersDetail[index];
		waypointArray[index] = L.latLng(md.latitude, md.longitude);
		var lapColor = md.tmpNbLap != null ? getLapColor(md.tmpNbLap).substring(1) : '0554A6';
	    initMarker(md, markerArray, index, lapColor + '; border-color: #E6EAF0');
		if (md.tmpNbLap != null && lapLayers.has(md.tmpNbLap)) {
			lapLayers.get(md.tmpNbLap).markers.push(markerArray[index]);
		}
	}
	if (routePolyline != null) {
	    try {
	        var coords = JSON.parse(routePolyline);
			var waypointSplitIdx = mapWaypointsToPolyline(markersDetail, coords);
			var sortedLaps = Array.from(laps.entries()).sort((a, b) => a[0] - b[0]);
			sortedLaps.forEach(([lap, indices], i) => {
				if (indices.length < 1) return;
				var from;
				var to = waypointSplitIdx[indices[indices.length - 1]];
				if (i > 0) {
					var prevLapIndices = sortedLaps[i - 1][1];
					from = waypointSplitIdx[prevLapIndices[prevLapIndices.length - 1]];
				} else {
					from = waypointSplitIdx[indices[0]];
				}
				if (to <= from) return;
				var segCoords = coords.slice(from, to + 1);
				var color = getLapColor(lap);
				var polyline = L.polyline(segCoords, {
				    color: color,
				    weight: 4,
					opacity: 0.85,
				    smoothFactor: 1
				}).addTo(map);
				var decorator = L.polylineDecorator(polyline, {
				    patterns: [{
				        offset: 25,
				        repeat: 250,
				        symbol: L.Symbol.arrowHead({
				            pixelSize: 10,
				            pathOptions: {
				                fillOpacity: 1,
				                weight: 0,
				                color: color
				            }
				        })
				    }]
				}).addTo(map);
				if (lapLayers.has(lap)) {
					lapLayers.get(lap).polylines.push(polyline, decorator);
				}
			});
	    } catch (e) {
			console.error('Errore disegno polyline', e);
		}
	}
	addSubtripsLegend(laps, markersDetail);
	if (markerArray.length > 0) {
		var featureGroup = L.featureGroup(markerArray).addTo(map);
		map.fitBounds(featureGroup.getBounds());
	}
	L.control.browserPrint({
		printLayer: null,
		printModes: ["Landscape"],
		manualMode: false
	}).addTo(map);
}

function setLayerVisible(maplibreMap, source, visible) {
	if (!maplibreMap || !maplibreMap.getStyle()) return;
	const visibility = visible ? 'visible' : 'none';
	maplibreMap.getStyle().layers.forEach(layer => {
		if (layer.source === source) {
			maplibreMap.setLayoutProperty(layer.id, 'visibility', visibility);
		}
	});
}

function initResponseDetailMapVector(mapUrl, apiKey, mapAttr, route, routePolyline) {
	try {
		map.remove();
	} catch (Exception) {
	}
	const buildTransformRequest = (url, resourceType) => {
		if (resourceType === 'Tile' && url.startsWith('https://api.myptv.com')) {
			return { url, headers: { 'ApiKey': apiKey } };
		}
		return { url };
	};
	var normalLayer = L.maplibreGL({
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
		maxZoom: 18,
		style: mapUrl,
		transformRequest: buildTransformRequest
	});
	var satelliteLayer = L.maplibreGL({
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
		maxZoom: 18,
		style: 'scripts/ptv_hybrid_truckrestrictions_style.json',
		transformRequest: buildTransformRequest
	});
	map = L.map('itineraryMapDiv', {
	    layers: [normalLayer],
	    zoomControl: true
	});
	map.createPane('restrictionsPane');
	map.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsProxy = L.layerGroup();
	var lowEmissionsProxy = L.layerGroup();
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer,
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy,
		"Zone basse emissioni": lowEmissionsProxy
	};
	L.control.layers(baseMaps, overlays, { position: 'topright' }).addTo(map);
	map.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
	    } else if (e.layer === lowEmissionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
		}
	});
	map.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
		} else if (e.layer === lowEmissionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
	    }
	});
	if (route == null || route.length < 3) {
		map.setView(defaultPoint, defaultZoom);
	}
	var markersDetail = JSON.parse(route);
	var markerArray = [];
	var waypointArray = [];
	var laps = groupByLap(markersDetail);
	lapLayers.clear();
	laps.forEach((_, lap) => lapLayers.set(lap, { markers: [], polylines: [] }));
	for (var index = 0; index < markersDetail.length; index++) {
	    var md = markersDetail[index];
		waypointArray[index] = L.latLng(md.latitude, md.longitude);
		var lapColor = md.tmpNbLap != null ? getLapColor(md.tmpNbLap).substring(1) : '0554A6';
	    initMarker(md, markerArray, index, lapColor + '; border-color: #E6EAF0');
		if (md.tmpNbLap != null && lapLayers.has(md.tmpNbLap)) {
			lapLayers.get(md.tmpNbLap).markers.push(markerArray[index]);
		}
	}
	if (routePolyline != null) {
	    try {
	        var coords = JSON.parse(routePolyline);
			var waypointSplitIdx = mapWaypointsToPolyline(markersDetail, coords);
			var sortedLaps = Array.from(laps.entries()).sort((a, b) => a[0] - b[0]);
			sortedLaps.forEach(([lap, indices], i) => {
				if (indices.length < 1) return;
				var from;
				var to = waypointSplitIdx[indices[indices.length - 1]];
				if (i > 0) {
					var prevLapIndices = sortedLaps[i - 1][1];
					from = waypointSplitIdx[prevLapIndices[prevLapIndices.length - 1]];
				} else {
					from = waypointSplitIdx[indices[0]];
				}
				if (to <= from) return;
				var segCoords = coords.slice(from, to + 1);
				var color = getLapColor(lap);
				var polyline = L.polyline(segCoords, {
					color: color,
					weight: 4,
					opacity: 0.85,
					smoothFactor: 1
				}).addTo(map);
				var decorator = L.polylineDecorator(polyline, {
					patterns: [{
						offset: 25,
						repeat: 250,
						symbol: L.Symbol.arrowHead({
							pixelSize: 10,
							pathOptions: {
								fillOpacity: 1,
								weight: 0,
								color: color
							}
						})
					}]
				}).addTo(map);
				if (lapLayers.has(lap)) {
					lapLayers.get(lap).polylines.push(polyline, decorator);
				}
			});
	    } catch (e) {
			console.error('Errore disegno polyline', e);
		}
	}
	addSubtripsLegend(laps, markersDetail);
	if (markerArray.length > 0) {
		var featureGroup = L.featureGroup(markerArray).addTo(map);
		map.fitBounds(featureGroup.getBounds());
	}
	L.control.browserPrint({
		printLayer: null,
		printModes: ["Landscape"],
		manualMode: false
	}).addTo(map);
}

function precise_round(num, decimals) {
	return Math.round(num * Math.pow(10, decimals)) / Math.pow(10, decimals);
}

function updateInputText(latLng) {
	var inputs = document.getElementsByTagName("input");
	for (var i = 0; i < inputs.length; i++) {
		if (endsWith(inputs[i].name, "itemLat")) {
			inputs[i].value = precise_round(latLng.lat, 7);
		}
		if (endsWith(inputs[i].name, "itemLon")) {
			inputs[i].value = precise_round(latLng.lng, 7);
		}
	}
}

function initMapLeaflet(mapUrl, apiKey, mapAttr, json) {
	try {
		map.remove();
	} catch (Exception) {
	}
	var coords = JSON.parse(json);
	var hasPoint = coords.lat != null && coords.lon != null;
	var center = hasPoint ? coords : defaultPoint;
	var zoom = hasPoint ? 15 : defaultZoom;
	var centerLatLng = Array.isArray(center) ? center : [center.lat, center.lon];
	var normalLayer = L.tileLayer(mapUrl + apiKey, {
	    maxZoom: 18,
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	});
	var satelliteLayer = L.tileLayer(
	    'https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/jpeg?size=256&style=explore.satellite.day&apiKey=' + apiKey, {
	        maxZoom: 18,
			attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	    }
	);
	map = L
		.map(
			'itineraryMapDiv',
			{
				center: centerLatLng,
				zoom: zoom,
				layers: normalLayer,
				zoomControl: true
			});
	map.doubleClickZoom.disable();
	map.createPane('restrictionsPane');
	map.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsDay = makeRestrictionsLayer('explore.day', apiKey, mapAttr);
	var restrictionsSat = makeRestrictionsLayer('explore.satellite.day', apiKey, mapAttr);
	var restrictionsProxy = L.layerGroup();
	var currentBase = 'day';
	var restrictionsOn = false;
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer,
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy
	};
	L.control.layers(baseMaps, overlays, { position: 'topright' }).addTo(map);
	map.on('baselayerchange', function (e) {
	    currentBase = (e.name === 'Normale') ? 'day' : 'sat';
	    refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	});
	map.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = true;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	map.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = false;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	var marker;
	if (coords.lat != null && coords.lon != null) {
		marker = L.marker([center.lat, center.lon], {
			draggable: true
		}).addTo(map);
		marker.on('drag', function(e) {
			updateInputText(marker.getLatLng());
		});
	}
	map.on('dblclick', function(e) {
		if (marker != null) {
			map.removeLayer(marker);
		}
		marker = L.marker([e.latlng.lat, e.latlng.lng], {
			draggable: true
		}).addTo(map);
		marker.on('drag', function(e) {
			updateInputText(marker.getLatLng());
		});
		updateInputText(e.latlng);
	});
}

function initMapLeafletVector(mapUrl, apiKey, mapAttr, json) {
	try {
		map.remove();
	} catch (Exception) {
	}
	const buildTransformRequest = (url, resourceType) => {
		if (resourceType === 'Tile' && url.startsWith('https://api.myptv.com')) {
			return { url, headers: { 'ApiKey': apiKey } };
		}
		return { url };
	};
	var normalLayer = L.maplibreGL({
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
		maxZoom: 18,
		style: mapUrl,
		transformRequest: buildTransformRequest
	});
	var satelliteLayer = L.maplibreGL({
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
		maxZoom: 18,
		style: 'scripts/ptv_hybrid_truckrestrictions_style.json',
		transformRequest: buildTransformRequest
	});
	var coords = JSON.parse(json);
	var hasPoint = coords.lat != null && coords.lon != null;
	var center = hasPoint ? coords : defaultPoint;
	var zoom = hasPoint ? 15 : defaultZoom;
	var centerLatLng = Array.isArray(center) ? center : [center.lat, center.lon];
	map = L
		.map(
			'itineraryMapDiv',
			{
				center: centerLatLng,
				zoom: zoom,
				layers: normalLayer,
				zoomControl: true
			});
	map.doubleClickZoom.disable();
	map.createPane('restrictionsPane');
	map.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsProxy = L.layerGroup();
	var lowEmissionsProxy = L.layerGroup();
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer,
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy,
		"Zone basse emissioni": lowEmissionsProxy
	};
	L.control.layers(baseMaps, overlays, { position: 'topright' }).addTo(map);
	map.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
	    } else if (e.layer === lowEmissionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
		}
	});
	map.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
		} else if (e.layer === lowEmissionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
	    }
	});
	var marker;
	if (coords.lat != null && coords.lon != null) {
		marker = L.marker([center.lat, center.lon], {
			draggable: true
		}).addTo(map);
		marker.on('drag', function(e) {
			updateInputText(marker.getLatLng());
		});
	}
	map.on('dblclick', function(e) {
		if (marker != null) {
			map.removeLayer(marker);
		}
		marker = L.marker([e.latlng.lat, e.latlng.lng], {
			draggable: true
		}).addTo(map);
		marker.on('drag', function(e) {
			updateInputText(marker.getLatLng());
		});
		updateInputText(e.latlng);
	});
}

function initPositionMapLeaflet(mapUrl, apiKey, mapAttr, json) {
	try {
		map.remove();
	} catch (Exception) {
	}
	var coords = JSON.parse(json);
	var hasPoint = coords.lat != null && coords.lon != null;
	var center = hasPoint ? coords : defaultPoint;
	var zoom = hasPoint ? 15 : defaultZoom;
	var centerLatLng = Array.isArray(center) ? center : [center.lat, center.lon];
	var normalLayer = L.tileLayer(mapUrl + apiKey, {
	    maxZoom: 18,
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	});
	var satelliteLayer = L.tileLayer(
	    'https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/jpeg?size=256&style=explore.satellite.day&apiKey=' + apiKey, {
	        maxZoom: 18,
			attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	    }
	);
	map = L
		.map(
			'positionMap',
			{
				center: centerLatLng,
				zoom: zoom,
				layers: normalLayer,
				zoomControl: true
			});
	map.doubleClickZoom.disable();
	map.createPane('restrictionsPane');
	map.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsDay = makeRestrictionsLayer('explore.day', apiKey, mapAttr);
	var restrictionsSat = makeRestrictionsLayer('explore.satellite.day', apiKey, mapAttr);
	var restrictionsProxy = L.layerGroup();
	var currentBase = 'day';
	var restrictionsOn = false;
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer,
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy
	};
	L.control.layers(baseMaps, overlays, { position: 'topright' }).addTo(map);
	map.on('baselayerchange', function (e) {
	    currentBase = (e.name === 'Normale') ? 'day' : 'sat';
	    refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	});
	map.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = true;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	map.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = false;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	var marker;
	if (coords.lat != null && coords.lon != null) {
		marker = L.marker([center.lat, center.lon]).addTo(map);
	}
}

function initPositionMapLeafletVector(mapUrl, apiKey, mapAttr, json) {
	try {
		map.remove();
	} catch (Exception) {
	}
	const buildTransformRequest = (url, resourceType) => {
		if (resourceType === 'Tile' && url.startsWith('https://api.myptv.com')) {
			return { url, headers: { 'ApiKey': apiKey } };
		}
		return { url };
	};
	var normalLayer = L.maplibreGL({
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
		maxZoom: 18,
		style: mapUrl,
		transformRequest: buildTransformRequest
	});
	var satelliteLayer = L.maplibreGL({
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
		maxZoom: 18,
		style: 'scripts/ptv_hybrid_truckrestrictions_style.json',
		transformRequest: buildTransformRequest
	});
	var coords = JSON.parse(json);
	var hasPoint = coords.lat != null && coords.lon != null;
	var center = hasPoint ? coords : defaultPoint;
	var zoom = hasPoint ? 15 : defaultZoom;
	var centerLatLng = Array.isArray(center) ? center : [center.lat, center.lon];
	map = L
		.map(
			'positionMap',
			{
				center: centerLatLng,
				zoom: zoom,
				layers: normalLayer,
				zoomControl: true
			});
	map.doubleClickZoom.disable();
	map.createPane('restrictionsPane');
	map.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsProxy = L.layerGroup();
	var lowEmissionsProxy = L.layerGroup();
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer,
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy,
		"Zone basse emissioni": lowEmissionsProxy
	};
	L.control.layers(baseMaps, overlays, { position: 'topright' }).addTo(map);
	map.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
	    } else if (e.layer === lowEmissionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
		}
	});
	map.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
		} else if (e.layer === lowEmissionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
	    }
	});
	var marker;
	if (coords.lat != null && coords.lon != null) {
		marker = L.marker([center.lat, center.lon]).addTo(map);
	}
}

function centerMapOnMarker(lat, lon, route) {
	if (map != null) {
		map.panTo(new L.LatLng(lat, lon));
		if (currentFeatureGroup) {
			map.removeLayer(currentFeatureGroup);
		}
		var markerArray = [];

		for (var index = 0; index < route.length; index++) {
			var md = route[index];
			initMarker(md, markerArray, index);
		}
		currentFeatureGroup = L.featureGroup(markerArray).addTo(map);
	}
}

function nextFocus(elementName) {
	reg = /\d/;
	num = reg.exec(elementName);
	if (num) {
		elementName = elementName.replace(num, parseInt(num) + 1);
		element = document.getElementById(elementName);
		element.focus();
	}
}

function onPlantSelect(rowId) {
	var txtField = document
		.getElementById("response-detail-form:markerIdHiddenInput");
	txtField.value = rowId;
	selectTruckFromMarker();
}

