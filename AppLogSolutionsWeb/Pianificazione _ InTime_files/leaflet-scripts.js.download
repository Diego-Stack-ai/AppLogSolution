		});
		monitoringMap.on('overlayadd', function (e) {
		    if (e.layer === restrictionsProxy) {
		        restrictionsOn = true;
		        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
		    }
