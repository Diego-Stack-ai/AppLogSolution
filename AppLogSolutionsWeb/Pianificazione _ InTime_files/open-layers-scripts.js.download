function handleKeyPress(e) {
	if (e.keyCode == 13) {
		calculateCorrectiveFactors();
		return false;
	}
}

function handleKeyPressAmountConfirmTravels(e) {
	if (e.keyCode == 13) {
		calculateAmountCurierTravels();
		return false;
	}
}

function handleKeyPressAdditionalCostsConfirmTravels(e) {
	if (e.keyCode == 13) {
		calculateAdditionalCostsCurierTravels();
		return false;
	}
}

function handleKeyPressCalculateQuantities(e) {
	if (e.keyCode == 13) {
		calculateQuantities();
		return false;
	}
}

function changeSummaryCostTableScrollableWidth() {
	document.getElementById("summary-costs:hidden-scroll-col-width").value = document.body.offsetWidth - 212;
	updateSummaryCostTable();
}

function changeSummaryCostTableScrollableHeight() {
	document.getElementById("summary-costs:hidden-scroll-col-height").value = document.body.offsetHeight - 50;
	updateSummaryCostTable();
}