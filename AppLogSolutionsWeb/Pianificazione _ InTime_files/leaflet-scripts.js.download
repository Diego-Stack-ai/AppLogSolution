function buildRow(coord, md, marker, buildIcon, selectedIds, updateHiddenInput, syncCheckboxes) {
	const row = document.createElement('div');
	row.style.cssText = `display: flex; align-items: center; gap: 8px; padding: 5px 10px; cursor: pointer;
	 border-bottom: 1px solid #f0f0f0; transition: background .15s;`;
	row.onmouseenter = () => row.style.background = '#f9f9f9';
	row.onmouseleave = () => row.style.background = '';
	const dot = document.createElement('span');
	dot.style.cssText = `width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
	 background-color: ${md.color}; border: 1px solid ${md.borderColor};`;
	const label = document.createElement('span');
	label.style.cssText = 'flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;';
	const seq = (coord.index != null && coord.index !== '') ? '[' + coord.index + '] ' : '';
	label.title = seq + (md.truck ? md.truck + ' - ' : '') + coord.name + (coord.productCategory ? ' - ' + coord.productCategory + ' ' + coord.quantity : '');
	label.textContent = label.title;
	const chk = document.createElement('input');
	chk.type = 'checkbox';
	chk.checked = selectedIds.has(coord.id);
	chk.style.cursor = 'pointer';
	chk.dataset.coordId = coord.id;
	const toggle = () => {
		if (selectedIds.has(coord.id)) {
			selectedIds.delete(coord.id);
			chk.checked = false;
			marker.setIcon(buildIcon(false));
		} else {
			selectedIds.add(coord.id);
			chk.checked = true;
			marker.setIcon(buildIcon(true));
		}
		updateHiddenInput();
	};
	row.onclick = (e) => {
		e.stopPropagation();
		toggle();
	}
	chk.onclick = e => e.stopPropagation();
	chk.onchange = toggle;
	row.append(dot, label, chk);
	return row;
}

function initClusterPanel(itinerariesMap, json, selectedIds, updateHiddenInput, layersControl, opts) {
	opts = opts || {};
	const enhanced = !!opts.enhanced;
	const drawArrows = enhanced && opts.arrows !== false;
	const legendTitle = opts.legendTitle || 'Mezzi';
	const panel = document.createElement('div');
	panel.id = 'cluster-select-panel';
	panel.style.cssText = `display: none; position: absolute; z-index: 1000;
	 background: white; border: 1px solid #ccc; border-radius: 6px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
	 min-width: 220px; max-width: 300px; font-family: san-serif; font-size: 13px; overflow: hidden;`;
 	const panelHeader = document.createElement('div');
	panelHeader.style.cssText = `display: flex; justify-content: space-between; align-items: center;
	 padding: 6px 10px; background: #f5f5f5; border-bottom: 1px solid #ddd; font-weight: bold;`;
	const panelTitle = document.createElement('span');
	const panelClose = document.createElement('button');
	panelClose.textContent = '✕';
	panelClose.style.cssText = 'border: none; background: none; cursor: pointer; font-size: 14px; padding: 0;';
	panelClose.onclick = (e) => {
		e.stopPropagation();
		e.preventDefault();
		panel.style.display = 'none';
	};
	panelHeader.append(panelTitle, panelClose);
	const panelList = document.createElement('div');
	panelList.style.cssText = 'max-height: 220px; overflow-y: auto; padding: 4px 0;';
	panel.append(panelHeader, panelList);
	const mapContainer = document.getElementById('itinerariesMap');
	mapContainer.style.position = 'relative';
	mapContainer.appendChild(panel);
	panelList.addEventListener('wheel', e => e.stopPropagation(), { passive: true });
	itinerariesMap.on('click', () => panel.style.display = 'none');
	function syncCheckboxes() {
		panelList.querySelectorAll('input[type="checkbox"][data-coord-id]').forEach(chk => {
			const id = chk.dataset.coordId;
			chk.checked = selectedIds.has(id) || selectedIds.has(Number(id));
		});
	}
	function showClusterPanel(containerPoint, markerInfos) {
		panelTitle.textContent = `${markerInfos.length} destinazioni`;
		panelList.innerHTML = '';
		markerInfos.forEach(({ coord, md, marker, buildIcon }) =>
			panelList.appendChild(buildRow(coord, md, marker, buildIcon, selectedIds, updateHiddenInput, syncCheckboxes)));
		let left = containerPoint.x + 10;
		let top = containerPoint.y + 10;
		panel.style.display = 'block';
		requestAnimationFrame(() => {
			if (left + panel.offsetWidth > mapContainer.offsetWidth - 10) left = containerPoint.x - panel.offsetWidth - 10;
			if (top + panel.offsetHeight > mapContainer.offsetHeight - 10) top = containerPoint.y - panel.offsetHeight - 10;
			panel.style.left = left + 'px';
			panel.style.top = top + 'px';
		});
	}
	function buildSectorIcon(colorCounts, total, size) {
		const r = size / 2;
		const borderW = 2;
		const cx = r, cy = r;
		let startAngle = -Math.PI / 2;
		let fillPaths = '';
		let borderArcs = '';
		for (const { color, borderColor, count } of colorCounts) {
			const slice = (count / total) * 2 * Math.PI;
			const endAngle = startAngle + slice;
			const cosStart = Math.cos(startAngle), sinStart = Math.sin(startAngle);
			const cosEnd = Math.cos(endAngle), sinEnd = Math.sin(endAngle);
			const largeArc = slice > Math.PI ? 1 : 0;
			fillPaths += `<path d="M${cx},${cy} L${cx + r * cosStart},${cy + r * sinStart} A${r},${r} 0 ${largeArc}, 1 ${cx + r * cosEnd},${cy + r * sinEnd} Z" fill="${color}" />`;
			borderArcs += `<path d="M${cx + r * cosStart},${cy + r * sinStart} A${r},${r} 0 ${largeArc}, 1 ${cx + r * cosEnd},${cy + r * sinEnd}" fill="none" stroke="${borderColor}" stroke-width="${borderW}" />`;
			startAngle = endAngle;
		}
		const fontSize = size < 38 ? 9 : 11;
		const svg = `<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}" xmlns="http://www.w3.org/2000/svg"
			style="border-radius: 50%; box-shadow: 0 1px 4px rgba(0,0,0,0.3); display: block;">${fillPaths}${borderArcs}
			<text x="${cx}" y="${cy}" text-anchor="middle" dominant-baseline="central" font-size="${fontSize}"
			font-weight="bold" fill="white" style="text-shadow: 0 0 3px rgba(0,0,0,0.9), 0 0 3px rgba(0,0,0,0.9);">x${total}</text></svg>`;
		return new L.DivIcon({
			html: svg,
			className: 'marker-cluster-custom',
			iconSize: [size, size],
			iconAnchor: [size / 2, size / 2]
		});
	}
	var markersDetail = JSON.parse(json);
	var waypointArray = [];
	document.querySelectorAll('style[data-pulse]').forEach(s => s.remove());
	const injectedPulseColors = new Set();
	const markerInfoMap = new Map();
	const markerColorMap = new Map();
	const sequenceLayer = L.layerGroup();
	if (drawArrows) {
		if (!itinerariesMap.getPane('sequencePane')) {
			itinerariesMap.createPane('sequencePane');
		}
		itinerariesMap.getPane('sequencePane').style.zIndex = 460;
		itinerariesMap.getPane('sequencePane').style.pointerEvents = 'none';
	}
	const vehicleEntries = [];
	const clusterGroup = L.markerClusterGroup({
		maxClusterRadius: enhanced ? function (zoom) {
			if (zoom <= 7) return 24;
			if (zoom <= 11) return 16;
			if (zoom <= 15) return 10;
			return 4;
		} : 40,
		showCoverageOnHover: !!enhanced,
		spiderfyOnMaxZoom: true,
		iconCreateFunction(cluster) {
			const childMarkers = cluster.getAllChildMarkers();
			const total = childMarkers.length;
			const size = total < 10 ? 22 : total < 100 ? 26 : 30;
			const countByColor = new Map();
			childMarkers.forEach(m => {
				const { color, borderColor } = markerColorMap.get(m) || { color: '#888888', borderColor: '#555555' };
				const key = color + '|' + borderColor;
				if (!countByColor.has(key)) countByColor.set(key, { color, borderColor, count: 0 });
                countByColor.get(key).count++;
			});
			if (countByColor.size === 1) {
				const { color, borderColor } = countByColor.values().next().value;
				return new L.DivIcon({
					html: `<div style="width: ${size}px; height: ${size}px; background: ${color}; color: #fff;
					 border-radius: 50%; border: 2px solid ${borderColor}; display: flex; align-items: center;
					 justify-content: center; font-size: ${size < 38 ? 9 : 11}px; font-weight: bold;
					 box-shadow: 0 1px 4px rgba(0,0,0,0.3); text-shadow: 0 0 3px rgba(0,0,0,0.9), 0 0 3px rgba(0,0,0,0.9)">x${total}</div>`,
					 className: 'marker-cluster-custom',
					 iconSize: [size, size],
					 iconAnchor: [size / 2, size / 2]
				});
			}
//			const colorCounts = Array.from(countByColor.entries()).map(([color, count]) => ({ color, count }));
			return buildSectorIcon(Array.from(countByColor.values()), total, size);
		}
	});
	for (var i = 0; i < markersDetail.length; i++) {
		var md = markersDetail[i];
		const routePoints = [];
		const vehicleEntry = { md: md, label: (md.truck != null && md.truck !== '') ? md.truck : ('Mezzo ' + (i + 1)), markers: [], routeLayers: [], visible: true };
		const pulseClass = 'pulse' + md.borderColor.replace(/[^a-zA-Z0-9]/g, '');
		if (!injectedPulseColors.has(pulseClass)) {
			injectedPulseColors.add(pulseClass);
			const style = document.createElement('style');
			style.setAttribute('data-pulse', pulseClass);
			style.textContent = `@keyframes ${pulseClass} {
				0% { box-shadow: 0 0 0 2px ${md.borderColor}, 0 0 0 2px ${md.borderColor}; }
				70% { box-shadow: 0 0 0 2px ${md.borderColor}, 0 0 0 8px transparent; }
				100% { box-shadow: 0 0 0 2px ${md.borderColor}, 0 0 0 8px transparent; }
			}`;
			document.head.appendChild(style);
		}
		for (var j = 0; j < md.coords.length; j++) {
			var coord = md.coords[j];
			const buildIcon = (function(mdRef, coordRef, pc) {
				return function(selected) {
					const size = selected ? 18 : 12;
					return new L.DivIcon({
						className: 'icon-div',
						html: '<div style="'
							+ 'width: ' + size + 'px; height: ' + size + 'px; '
							+ 'display: flex; align-items: center; justify-content: center; '
							+ 'background-color: ' + mdRef.color
							+ (coordRef.isProposal ? '; opacity: 0.4' : '')
							+ '; color: ' + mdRef.fontColor
							+ '; border-style: solid; border-width: ' + (selected ? '2px' : '1px')
							+ '; border-color: ' + mdRef.borderColor
							+ (coordRef.noBorderRadius || coordRef.isProposal ? '' : '; border-radius: 50%')
							+ '; font-size: 7px'
							+ (coordRef.isProposal ? '; transform: rotate(45deg)' : '')
							+ (selected ? '; animation: ' + pc + ' 1.2s infinite;' : '')
							+ '"><span'
							+ (coordRef.isProposal ? ' style="display: block; transform: rotate(-45deg);"' : '')
							+ '>' + (coordRef.index != null ? coordRef.index : '')
							+ '</span></div>',
						iconSize: [size, size],
						iconAnchor: [size / 2, size / 2]
					});
				};
			})(md, coord, pulseClass);
			const currentCoord = coord;
			const marker = L.marker([coord.lat, coord.lon]).setIcon(buildIcon(false))
				.bindTooltip(
					((enhanced && coord.index != null) ? '[' + coord.index + '] ' : '') +
					(md.truck != null ? md.truck + ' - ' : '') + coord.name +
					(coord.productCategory ? '<br />' + coord.productCategory + ' ' + coord.quantity : '') +
					((coord.deliveryFrom || coord.deliveryTo) ? '<br />Consegna: ' + (coord.deliveryFrom || '') + ' - ' + (coord.deliveryTo || '') : '') +
					((coord.breakFrom || coord.breakTo) && coord.breakFrom !== coord.breakTo ? '<br />Pausa: ' + (coord.breakFrom || '') + ' - ' + (coord.breakTo || '') : '') +
					(coord.notes ? '<br />Note: ' + coord.notes : ''),
					{ className: 'leaflet-tooltip' }
				);
			marker.on('click', function(e) {
				L.DomEvent.stopPropagation(e);
				if (selectedIds.has(currentCoord.id)) {
					selectedIds.delete(currentCoord.id);
					marker.setIcon(buildIcon(false));
				} else {
					selectedIds.add(currentCoord.id);
					marker.setIcon(buildIcon(true));
				}
				updateHiddenInput();
				syncCheckboxes();
			});
			markerInfoMap.set(marker, { coord: currentCoord, md, buildIcon });
			markerColorMap.set(marker, { color: md.color, borderColor: md.borderColor });
			clusterGroup.addLayer(marker);
			vehicleEntry.markers.push(marker);
			waypointArray.push(L.latLng(coord.lat, coord.lon));
			if (drawArrows && coord.index != null && !coord.isProposal) {
				routePoints.push({ idx: Number(coord.index), latlng: L.latLng(coord.lat, coord.lon) });
			}
		}
		if (drawArrows && routePoints.length > 1) {
			routePoints.sort(function (a, b) { return a.idx - b.idx; });
			const latlngs = routePoints.map(function (p) { return p.latlng; });
			const casing = L.polyline(latlngs, { pane: 'sequencePane', color: '#ffffff', weight: 4, opacity: 0.6 });
			const line = L.polyline(latlngs, { pane: 'sequencePane', color: md.color, weight: 2, opacity: 0.9 });
			const arrows = L.polylineDecorator(line, {
				pane: 'sequencePane',
				patterns: [{
					offset: 12,
					repeat: 70,
					symbol: L.Symbol.arrowHead({
						pixelSize: 11,
						polygon: false,
						pathOptions: { pane: 'sequencePane', stroke: true, color: md.color, weight: 2, opacity: 0.95 }
					})
				}]
			});
			sequenceLayer.addLayer(casing);
			sequenceLayer.addLayer(line);
			sequenceLayer.addLayer(arrows);
			vehicleEntry.routeLayers.push(casing, line, arrows);
		}
		vehicleEntries.push(vehicleEntry);
	}
	clusterGroup.on('clustermouseover', function(e) {
		const childMarkers = e.layer.getAllChildMarkers();
		const tooltipLines = childMarkers.map(m => {
			const tt = m.getTooltip();
			return tt ? tt.getContent() : null;
		}).filter(Boolean);
		if (tooltipLines.length === 0) return;
		const visible = tooltipLines.slice(0, PANEL_PAGE_SIZE);
		const hiddenCount = tooltipLines.length - visible.length;
		let content = visible.join('<hr style="margin: 3px 0; border-color: #ddd">');
		if (hiddenCount > 0) {
			content += '<hr style="margin: 3px 0; border-color: #ddd">'
				+ '<span style="color: #5578c8; font-size: 11px;">e altri ' + hiddenCount + '...</span>';
		}
		e.layer.bindTooltip(content, {
			className: 'leaflet-tooltip',
			sticky: true
		}).openTooltip();
	});
	clusterGroup.on('clustermouseout', function(e) {
		e.layer.closeTooltip();
		e.layer.unbindTooltip();
	});
	clusterGroup.on('clusterclick', function(e) {
		L.DomEvent.stopPropagation(e);
		panel.style.display = 'none';
		const childMarkers = e.layer.getAllChildMarkers();
		const infos = childMarkers.map(m => {
			const info = markerInfoMap.get(m);
			return info ? { marker: m, ...info } : null;
		}).filter(Boolean);
		const cp = itinerariesMap.latLngToContainerPoint(e.layer.getLatLng());
		showClusterPanel(cp, infos);
	});
	itinerariesMap.addLayer(clusterGroup);
	if (enhanced && layersControl && sequenceLayer.getLayers().length > 0) {
		layersControl.addOverlay(sequenceLayer, 'Sequenza consegne');
	}
	if (enhanced) {
	function setVehicleVisible(entry, visible) {
		if (entry.visible === visible) return;
		entry.visible = visible;
		if (visible) {
			clusterGroup.addLayers(entry.markers);
			entry.routeLayers.forEach(function (l) { sequenceLayer.addLayer(l); });
		} else {
			clusterGroup.removeLayers(entry.markers);
			entry.routeLayers.forEach(function (l) { sequenceLayer.removeLayer(l); });
		}
	}
	if (vehicleEntries.length > 0) {
		function legendText(md) {
			const seen = {}, uniq = [];
			[md.dayString, md.drivingTruckPlate, md.truckCode, md.truckPlate, md.driver].forEach(function (v) {
				if (v != null && String(v).trim() !== '' && !seen[v]) { seen[v] = 1; uniq.push(v); }
			});
			const idx = (md.truckIndex != null ? md.truckIndex + ' - ' : '');
			return idx + (uniq.length ? uniq.join(' - ') : (md.truck || ''));
		}
		const legend = L.control({ position: 'topright' });
		legend.onAdd = function () {
			const box = L.DomUtil.create('div', 'leaflet-bar itineraries-legend');
			box.style.cssText = 'background:#fff; box-shadow:0 1px 4px rgba(0,0,0,.3); font-size:12px; line-height:1.4; max-width:260px; box-sizing:border-box;';
			const head = L.DomUtil.create('a', '', box);
			head.href = '#';
			head.style.cssText = 'display:block; width:auto; height:auto; line-height:normal; padding:5px 10px; font-weight:bold; white-space:nowrap; cursor:pointer; color:#333;';
			const list = L.DomUtil.create('div', '', box);
			list.style.cssText = 'display:none; max-height:300px; overflow:auto; padding:4px 8px; border-top:1px solid #eee; min-width:160px; box-sizing:border-box;';
			let open = false;
			function renderHead() { head.textContent = (open ? '▾ ' : '▸ ') + legendTitle + ' (' + vehicleEntries.length + ')'; }
			renderHead();
			L.DomEvent.on(head, 'click', function (e) { L.DomEvent.stop(e); open = !open; list.style.display = open ? 'block' : 'none'; renderHead(); });
			const allLink = L.DomUtil.create('a', '', list);
			allLink.href = '#'; allLink.textContent = 'mostra tutti'; allLink.style.cssText = 'display:inline-block; width:auto; height:auto; line-height:normal; font-size:11px; color:#5578c8; margin-bottom:4px;';
			const rows = [];
			vehicleEntries.forEach(function (entry) {
				const row = document.createElement('label');
				row.style.cssText = 'display:flex; align-items:center; gap:6px; cursor:pointer; white-space:nowrap; padding:1px 0;';
				const chk = document.createElement('input');
				chk.type = 'checkbox'; chk.checked = true; chk.style.cursor = 'pointer'; chk.style.flexShrink = '0';
				chk.onchange = function () { setVehicleVisible(entry, chk.checked); };
				const dot = document.createElement('span');
				dot.style.cssText = 'width:11px; height:11px; border-radius:50%; flex-shrink:0; background:' + entry.md.color + '; border:1px solid ' + entry.md.borderColor + ';';
				const txt = document.createElement('span');
				txt.textContent = (entry.md.legendLabel || legendText(entry.md)) + ' (' + entry.markers.length + ')';
				txt.title = txt.textContent + ' — clic per isolare';
				txt.style.cssText = 'flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis;';
				txt.onclick = function (e) {
					e.preventDefault(); e.stopPropagation();
					vehicleEntries.forEach(function (other, k) { const vis = (other === entry); setVehicleVisible(other, vis); rows[k].checked = vis; });
				};
				row.append(chk, dot, txt);
				list.appendChild(row);
				rows.push(chk);
			});
			allLink.onclick = function (e) { e.preventDefault(); e.stopPropagation(); vehicleEntries.forEach(function (entry, k) { setVehicleVisible(entry, true); rows[k].checked = true; }); };
			L.DomEvent.disableClickPropagation(box);
			L.DomEvent.disableScrollPropagation(box);
			return box;
		};
		legend.addTo(itinerariesMap);
	}
	let selecting = false, selPoints = [], selPolygon = null, onSelToggle = null, selHintControl = null;
	function pointInPolygon(latlng, vertices) {
		let x = latlng.lng, y = latlng.lat, inside = false;
		for (let i = 0, j = vertices.length - 1; i < vertices.length; j = i++) {
			const xi = vertices[i].lng, yi = vertices[i].lat;
			const xj = vertices[j].lng, yj = vertices[j].lat;
			const intersect = ((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
			if (intersect) inside = !inside;
		}
		return inside;
	}
	function onSelMove(e) {
		if (!selPolygon || selPoints.length === 0) return;
		selPolygon.setLatLngs(selPoints.concat([e.latlng]));
	}
	function onSelClick(e) {
		selPoints.push(e.latlng);
		if (!selPolygon) {
			selPolygon = L.polygon(selPoints, { color: '#3388ff', weight: 1, dashArray: '4', fillOpacity: 0.1 }).addTo(itinerariesMap);
		} else {
			selPolygon.setLatLngs(selPoints);
		}
	}
	function onSelDblClick(e) {
		L.DomEvent.stop(e);
		finishAreaSelect();
	}
	function onSelKeyDown(e) {
		if (e.key === 'Escape') { stopAreaSelect(); }
	}
	function finishAreaSelect() {
		if (selPoints.length > 1 && selPoints[selPoints.length - 1].equals(selPoints[selPoints.length - 2])) {
			selPoints.pop();
		}
		if (selPoints.length >= 3) {
			let changed = false;
			markerInfoMap.forEach(function (info, marker) {
				if (info.coord.id == null) return;
				if (pointInPolygon(marker.getLatLng(), selPoints) && !selectedIds.has(info.coord.id)) {
					selectedIds.add(info.coord.id);
					marker.setIcon(info.buildIcon(true));
					changed = true;
				}
			});
			if (changed) { updateHiddenInput(); syncCheckboxes(); }
		}
		stopAreaSelect();
	}
	function showSelHint() {
		if (selHintControl) return;
		selHintControl = L.control({ position: 'bottomleft' });
		selHintControl.onAdd = function () {
			const box = L.DomUtil.create('div', 'leaflet-bar');
			box.style.cssText = 'background:#fff; padding:6px 10px; font-size:12px; color:#333; box-shadow:0 1px 4px rgba(0,0,0,.3);';
			box.textContent = "Clicca per aggiungere i vertici dell'area, doppio click per chiuderla, Esc per annullare";
			return box;
		};
		selHintControl.addTo(itinerariesMap);
	}
	function hideSelHint() {
		if (selHintControl) { itinerariesMap.removeControl(selHintControl); selHintControl = null; }
	}
	function startAreaSelect() {
		selecting = true;
		selPoints = [];
		itinerariesMap.dragging.disable();
		itinerariesMap.doubleClickZoom.disable();
		itinerariesMap.getContainer().style.cursor = 'crosshair';
		itinerariesMap.on('click', onSelClick);
		itinerariesMap.on('mousemove', onSelMove);
		itinerariesMap.on('dblclick', onSelDblClick);
		document.addEventListener('keydown', onSelKeyDown);
		showSelHint();
		if (onSelToggle) onSelToggle(true);
	}
	function stopAreaSelect() {
		selecting = false;
		if (selPolygon) { itinerariesMap.removeLayer(selPolygon); selPolygon = null; }
		selPoints = [];
		itinerariesMap.dragging.enable();
		itinerariesMap.doubleClickZoom.enable();
		itinerariesMap.getContainer().style.cursor = '';
		itinerariesMap.off('click', onSelClick);
		itinerariesMap.off('mousemove', onSelMove);
		itinerariesMap.off('dblclick', onSelDblClick);
		document.removeEventListener('keydown', onSelKeyDown);
		hideSelHint();
		if (onSelToggle) onSelToggle(false);
	}
	function toggleFullscreen() {
		const target = itinerariesMap.getContainer();
		if (!document.fullscreenElement) {
			(target.requestFullscreen || target.webkitRequestFullscreen || function () {}).call(target);
		} else {
			(document.exitFullscreen || document.webkitExitFullscreen || function () {}).call(document);
		}
	}
	if (window._itinFsHandler) { document.removeEventListener('fullscreenchange', window._itinFsHandler); }
	window._itinFsHandler = function () { try { itinerariesMap.invalidateSize(); } catch (ex) {} };
	document.addEventListener('fullscreenchange', window._itinFsHandler);
	let printer = null;
	function printMap() {
		try {
			if (!printer) { printer = L.browserPrint(itinerariesMap, { documentTitle: 'Itinerari', printLayer: null }); }
			printer.print(L.BrowserPrint.Mode.Landscape());
		} catch (ex) { console.error('Errore stampa mappa', ex); }
	}
	const tools = L.control({ position: 'topleft' });
	tools.onAdd = function () {
		const wrap = L.DomUtil.create('div', 'leaflet-bar itin-tools');
		wrap.style.position = 'relative';
		const btn = L.DomUtil.create('a', '', wrap);
		btn.href = '#'; btn.title = 'Strumenti';
		btn.innerHTML = '<i class="pi pi-bars"></i>';
		const menu = L.DomUtil.create('div', '', wrap);
		menu.style.cssText = 'position:absolute; top:0; left:34px; display:none; background:#fff; border:1px solid #bbb; border-radius:4px; box-shadow:0 1px 5px rgba(0,0,0,.4); min-width:170px; overflow:hidden; z-index:1000;';
		function makeItem(iconClass, label) {
			const a = L.DomUtil.create('a', '', menu);
			a.href = '#';
			a.innerHTML = '<i class="pi ' + iconClass + '" style="margin-right:8px; width:14px; text-align:center;"></i>' + label;
			a.style.cssText = 'display:flex; align-items:center; width:auto; height:auto; line-height:normal; padding:8px 12px; white-space:nowrap; font-size:13px; color:#333; text-align:left; border-bottom:1px solid #eee;';
			a.onmouseenter = function () { a.style.background = '#f3f6fb'; };
			a.onmouseleave = function () { a.style.background = a._active ? '#cfe3ff' : ''; };
			return a;
		}
		const fsItem = makeItem('pi-window-maximize', 'Schermo intero');
		const selItem = makeItem('pi-stop', 'Seleziona area');
		const printItem = makeItem('pi-print', 'Stampa');
		printItem.style.borderBottom = 'none';
		onSelToggle = function (active) {
			selItem._active = active;
			selItem.style.background = active ? '#cfe3ff' : '';
			selItem.innerHTML = '<i class="pi pi-stop" style="margin-right:8px; width:14px; text-align:center;"></i>' + (active ? 'Annulla selezione' : 'Seleziona area');
		};
		function closeMenu() { menu.style.display = 'none'; }
		L.DomEvent.on(btn, 'click', function (e) { L.DomEvent.stop(e); menu.style.display = (menu.style.display === 'none' ? 'block' : 'none'); });
		L.DomEvent.on(fsItem, 'click', function (e) { L.DomEvent.stop(e); closeMenu(); toggleFullscreen(); });
		L.DomEvent.on(selItem, 'click', function (e) { L.DomEvent.stop(e); closeMenu(); if (selecting) { stopAreaSelect(); } else { startAreaSelect(); } });
		L.DomEvent.on(printItem, 'click', function (e) { L.DomEvent.stop(e); closeMenu(); printMap(); });
		L.DomEvent.disableClickPropagation(wrap);
		return wrap;
	};
	tools.addTo(itinerariesMap);
	}

	if (waypointArray != null && waypointArray.length > 0) {
		itinerariesMap.fitBounds(L.latLngBounds(waypointArray));
	}
}

function initItinerariesMap(mapUrl, apiKey, mapAttr, json, opts) {
	opts = opts || {};
	const useRetina = !!opts.enhanced && opts.retina !== false;
	try {
		itinerariesMap.remove();
	} catch (Exception) {
	}
	const oldPanel = document.getElementById('cluster-select-panel');
    if (oldPanel) {
        oldPanel.remove();
    }
	const selectedIds = new Set();
	function updateHiddenInput() {
		var input = document.getElementById('response-detail-form:selectedDestinationsInput');
		if (input) {
			input.value = JSON.stringify(Array.from(selectedIds));
		}
		updateItinerariesSelectedRows();
	}
	const toRetina = u => /[?&]size=/.test(u) ? u.replace(/([?&]size=)\d+/, '$1512') : u + (u.indexOf('?') >= 0 ? '&' : '?') + 'size=512';
	var normalLayer = L.tileLayer(useRetina ? toRetina(mapUrl + apiKey) : (mapUrl + apiKey), {
	    maxZoom: 18,
	    tileSize: 256,
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	});
	var satelliteLayer = L.tileLayer(
	    'https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/jpeg?size=' + (useRetina ? '512' : '256') + '&style=explore.satellite.day&apiKey=' + apiKey, {
	        maxZoom: 18,
	        tileSize: 256,
			attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	    }
	);
	itinerariesMap = L.map('itinerariesMap', {
	    layers: [normalLayer],
	    zoomControl: true,
	    zoomSnap: 0.5,
	    zoomDelta: 0.5,
	    wheelPxPerZoomLevel: 120
	});
	itinerariesMap.setView(new L.LatLng(lat, lon), 5);
	itinerariesMap.createPane('restrictionsPane');
	itinerariesMap.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsDay = makeRestrictionsLayer('explore.day', apiKey, mapAttr, 1, useRetina ? 512 : 256);
	var restrictionsSat = makeRestrictionsLayer('explore.satellite.day', apiKey, mapAttr, 1, useRetina ? 512 : 256);
	var restrictionsProxy = L.layerGroup();
	var currentBase = 'day', restrictionsOn = false;
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer,
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy
	};
	var layersControl = L.control.layers(baseMaps, overlays, { position: 'topright' });
	layersControl.addTo(itinerariesMap);
	itinerariesMap.on('baselayerchange', function (e) {
	    currentBase = (e.name === 'Normale') ? 'day' : 'sat';
	    refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	});
	itinerariesMap.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = true;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	itinerariesMap.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = false;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	initClusterPanel(itinerariesMap, json, selectedIds, updateHiddenInput, layersControl, opts);
}

function initItinerariesMapVector(mapUrl, apiKey, mapAttr, json, opts) {
	try {
		itinerariesMap.remove();
	} catch (Exception) {
	}
	const selectedIds = new Set();
	function updateHiddenInput() {
		var input = document.getElementById('response-detail-form:selectedDestinationsInput');
		if (input) {
			input.value = JSON.stringify(Array.from(selectedIds));
		}
		updateItinerariesSelectedRows();
	}
	const buildTransformRequest = (url, resourceType) => {
		if (resourceType === 'Tile' && url.startsWith('https://api.myptv.com')) {
			return { url, headers: { 'ApiKey': apiKey } };
		}
		return { url };
	};
	var normalLayer = L.maplibreGL({
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
		maxZoom: 18,
		style: mapUrl,
		transformRequest: buildTransformRequest
	});
	var satelliteLayer = L.maplibreGL({
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
		maxZoom: 18,
		style: 'scripts/ptv_hybrid_truckrestrictions_style.json',
		transformRequest: buildTransformRequest
	});
	itinerariesMap = L.map('itinerariesMap', {
	    layers: [normalLayer],
	    zoomControl: true,
		maxZoom: 18,
		zoomSnap: 0.5,
		zoomDelta: 0.5,
		wheelPxPerZoomLevel: 120
	});
	itinerariesMap.setView(new L.LatLng(lat, lon), 5);
	itinerariesMap.createPane('restrictionsPane');
	itinerariesMap.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsProxy = L.layerGroup();
	var lowEmissionsProxy = L.layerGroup();
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer,
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy,
		"Zone basse emissioni": lowEmissionsProxy
	};
	var layersControl = L.control.layers(baseMaps, overlays, { position: 'topright' });
	layersControl.addTo(itinerariesMap);
	itinerariesMap.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
	    } else if (e.layer === lowEmissionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
		}
	});
	itinerariesMap.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
	    } else if (e.layer === lowEmissionsProxy) {
			setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
			setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
		}
	});
	initClusterPanel(itinerariesMap, json, selectedIds, updateHiddenInput, layersControl, opts);
}

function initItinerariesMapVectorHere(styleUrl, apiKey, mapAttr, json, opts) {
	opts = opts || {};
	try {
		itinerariesMap.remove();
	} catch (Exception) {
	}
	const oldPanel = document.getElementById('cluster-select-panel');
	if (oldPanel) {
		oldPanel.remove();
	}
	const selectedIds = new Set();
	function updateHiddenInput() {
		var input = document.getElementById('response-detail-form:selectedDestinationsInput');
		if (input) {
			input.value = JSON.stringify(Array.from(selectedIds));
		}
		updateItinerariesSelectedRows();
	}
	const transformRequest = function (url) {
		if (url.indexOf('hereapi.com') >= 0 && url.indexOf('apikey=') < 0 && url.indexOf('apiKey=') < 0) {
			return { url: url + (url.indexOf('?') >= 0 ? '&' : '?') + 'apikey=' + apiKey };
		}
		return { url: url };
	};
	var normalLayer = L.maplibreGL({
		attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
		maxZoom: 18,
		style: styleUrl,
		transformRequest: transformRequest
	});
	var satelliteLayer = L.tileLayer(
		'https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/jpeg?size=512&style=explore.satellite.day&apiKey=' + apiKey, {
			maxZoom: 18,
			tileSize: 256,
			attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
		}
	);
	itinerariesMap = L.map('itinerariesMap', {
		layers: [normalLayer],
		zoomControl: true,
		maxZoom: 18,
		zoomSnap: 0.5,
		zoomDelta: 0.5,
		wheelPxPerZoomLevel: 120
	});
	itinerariesMap.setView(new L.LatLng(lat, lon), 5);
	var restrictionsBase = L.tileLayer(
		'https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/png?size=512&style=explore.day' +
		'&features=vehicle_restrictions:active_and_inactive&apiKey=' + apiKey, {
			maxZoom: 18,
			tileSize: 256,
			attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
		}
	);
	var baseMaps = {
		"Normale (vettoriale)": normalLayer,
		"Satellitare": satelliteLayer,
		"Restrizioni camion": restrictionsBase
	};
	var layersControl = L.control.layers(baseMaps, {}, { position: 'topright' });
	layersControl.addTo(itinerariesMap);
	initClusterPanel(itinerariesMap, json, selectedIds, updateHiddenInput, layersControl, opts);
}

function initTrucksMap(mapUrl, apiKey, mapAttr, json) {
	try {
		trucksMap.remove();
	} catch (Exception) {
	}
	var normalLayer = L.tileLayer(mapUrl + apiKey, {
	    maxZoom: 18,
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	});
	var satelliteLayer = L.tileLayer(
	    'https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/jpeg?size=256&style=explore.satellite.day&apiKey=' + apiKey, {
	        maxZoom: 18,
			attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	    }
	);
	trucksMap = L.map('trucksMap', {
	    layers: [normalLayer],
	    zoomControl: true
	});
	trucksMap.setView(new L.LatLng(lat, lon), 5);
	trucksMap.createPane('restrictionsPane');
	trucksMap.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsDay = makeRestrictionsLayer('explore.day', apiKey, mapAttr);
	var restrictionsSat = makeRestrictionsLayer('explore.satellite.day', apiKey, mapAttr);
	var restrictionsProxy = L.layerGroup();
	var currentBase = 'day';
	var restrictionsOn = false;
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer,
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy
	};
	L.control.layers(baseMaps, overlays, { position: 'topright' }).addTo(trucksMap);
	trucksMap.on('baselayerchange', function (e) {
	    currentBase = (e.name === 'Normale') ? 'day' : 'sat';
	    refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	});
	trucksMap.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = true;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	trucksMap.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = false;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	var markersDetail = JSON.parse(json);
	var markerArray = [];
	var waypointArray = [];
	var index = 0;
	for (var i = 0; i < markersDetail.length; i++) {
		var md = markersDetail[i];
		const icon = new L.DivIcon({
			className: 'icon-div',
			html: `<div style="background-color: ` + md.color + `; color: ` + md.fontColor + `; text-align: center; vertical-align: middle; border-style: solid; border-width: 1px; border-color: ` + md.borderColor + `; border-radius: 50px; ` + `font-size: 7px;"><span>` + (md.truckIndex != null ? md.truckIndex : ``) + `</span></div>`,
			iconSize: [12, 12]
		});
		markerArray[index] = L
			.marker([md.lat, md.lon]).setIcon(icon).bindTooltip(md.code + ' - ' + md.plate, {
				className: 'leaflet-tooltip'
			}).addTo(trucksMap);
		waypointArray[index] = L.latLng(md.lat, md.lon);
		index++;
	}
	var bounds = L.latLngBounds(waypointArray);
	if (waypointArray != null && waypointArray.length != 0) {
		trucksMap.fitBounds(bounds);
	}
}

