function initGeoFencingAreasMap(mapUrl, apiKey, mapAttr, json, coordsJson) {
	try {
		geoFencingMap.remove();
	} catch (Exception) {
	}
	var normalLayer = L.tileLayer(mapUrl + apiKey, {
	    maxZoom: 18,
	    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	});
	var satelliteLayer = L.tileLayer(
	    'https://maps.hereapi.com/v3/base/mc/{z}/{x}/{y}/jpeg?size=256&style=explore.satellite.day&apiKey=' + apiKey, {
	        maxZoom: 18,
			attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear()
	    }
	);
	geoFencingMap = L.map('boundingBoxMap', {
	    layers: [normalLayer],
	    zoomControl: true
	});
	geoFencingMap.setView(new L.LatLng(lat, lon), 5);
	geoFencingMap.createPane('restrictionsPane');
	geoFencingMap.getPane('restrictionsPane').style.zIndex = 450;
	var restrictionsDay = makeRestrictionsLayer('explore.day', apiKey, mapAttr);
	var restrictionsSat = makeRestrictionsLayer('explore.satellite.day', apiKey, mapAttr);
	var restrictionsProxy = L.layerGroup();
	var currentBase = 'day';
	var restrictionsOn = false;
	var baseMaps = {
	    "Normale": normalLayer,
	    "Satellitare": satelliteLayer,
	};
	var overlays = {
	    "Restrizioni camion": restrictionsProxy
	};
	L.control.layers(baseMaps, overlays, { position: 'topright' }).addTo(geoFencingMap);
	geoFencingMap.on('baselayerchange', function (e) {
	    currentBase = (e.name === 'Normale') ? 'day' : 'sat';
	    refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	});
	geoFencingMap.on('overlayadd', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = true;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	geoFencingMap.on('overlayremove', function (e) {
	    if (e.layer === restrictionsProxy) {
	        restrictionsOn = false;
	        refreshRestrictionsProxy(restrictionsProxy, restrictionsOn, currentBase === 'day' ? restrictionsDay : restrictionsSat);
	    }
	});
	var bbox = JSON.parse(json);
	var bboxArray = [];
	var index = 0;
	for (var i = 0; i < bbox.length; i++) {
		var bb = bbox[i];
		for (var j = 0; j < bb.length; j++) {
			var bboxCoords = bb[j];
			bboxArray[index + j] = L.latLng(bboxCoords[0], bboxCoords[1]);
		}
		L.rectangle(bb, { color: "#ff7800", weight: 1 }).addTo(geoFencingMap);
		index = index + bb.length;
	}
	var bounds = L.latLngBounds(bboxArray);
	if (bboxArray != null && bboxArray.length != 0) {
		geoFencingMap.fitBounds(bounds);
	}
	var coords = JSON.parse(coordsJson);
	var coordsArray = [];
	index = 0;
	for (var i = 0; i < coords.length; i++) {
		var coord = coords[i];
		const icon = new L.DivIcon({
			className: 'icon-div',
			html: `<div style="background-color: rgb(109, 156, 189); color: rgb(109, 156, 189); border-radius: 50px; text-align: center; vertical-align: middle; font-size: 8px;">0</div>`,
			iconSize: [12, 12]
		});
		coordsArray[index++] = L.marker([coord.latitude, coord.longitude]).setIcon(icon).bindTooltip(coord.latitude + ", " + coord.longitude, {
			className: 'leaflet-tooltip'
		}).addTo(geoFencingMap);
	}
	bounds = L.latLngBounds(coordsArray);
	if (coordsArray != null && coordsArray.length != 0) {
		geoFencingMap.fitBounds(bounds);
	}
}

