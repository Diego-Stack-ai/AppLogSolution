rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Blocca tutto di default
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Input dei fornitori (upload PDF originari)
    // Client non puo' fare upload diretto in produzione. 
    // Opzionalmente se il web client fa upload, abilita scrittura qui.
    // L'upload del lenzuolone avverra' da admin o da cloud function, o utente autenticato.
    match /input_pdf_fornitore/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Mappe degli autisti (accesso pubblico tramite link)
    match /CONSEGNE/{cartellaData}/MAPPE_AUTISTI/{fileName} {
      allow read: if true;
    }

    // Cartella delle consegne (DDT tagliati e distinte PDF)
    match /CONSEGNE/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Scrittura solo da Cloud Function
    }
    
    // Archivio
    match /archivio_lenzuoloni_processati/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Scrittura solo da CF
    }

    // NUOVE REGOLE PER IL WORKFLOW CLOUD
    
    // Cartella dei report e mappe Johnson
    match /REPORTS/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Cartella temporanea dei DDT splittati
    match /split_ddt/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Scrittura solo da backend
    }

    // Cartella archivio cedolini
    match /cedolini/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Cartella navette per upload DDT
    match /DDT_NAVETTE/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
