		};
		var normalLayer = L.maplibreGL({
		    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
			maxZoom: 18,
			style: mapUrl,
			transformRequest: buildTransformRequest
		});
		var satelliteLayer = L.maplibreGL({
		    attribution: '&copy; ' + mapAttr + ' ' + new Date().getFullYear(),
			maxZoom: 18,
			style: 'scripts/ptv_hybrid_truckrestrictions_style.json',
			transformRequest: buildTransformRequest
		});
		monitoringMap = L.map('monitoringMap', {
		    layers: [normalLayer],
		    zoomControl: true
		});
		monitoringMap.setView(new L.LatLng(lat, lon), 5);
		monitoringMap.createPane('restrictionsPane');
		monitoringMap.getPane('restrictionsPane').style.zIndex = 450;
		var restrictionsProxy = L.layerGroup();
		var lowEmissionsProxy = L.layerGroup();
		var baseMaps = {
		    "Normale": normalLayer,
		    "Satellitare": satelliteLayer,
		};
		var overlays = {
		    "Restrizioni camion": restrictionsProxy,
			"Zone basse emissioni": lowEmissionsProxy
		};
		L.control.layers(baseMaps, overlays, { position: 'topright' }).addTo(monitoringMap);
		monitoringMap.on('overlayadd', function (e) {
		    if (e.layer === restrictionsProxy) {
				setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
				setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', true);
		    } else if (e.layer === lowEmissionsProxy) {
				setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
				setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', true);
			}
		});
		monitoringMap.on('overlayremove', function (e) {
		    if (e.layer === restrictionsProxy) {
				setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
				setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-tr', false);
			} else if (e.layer === lowEmissionsProxy) {
				setLayerVisible(normalLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
				setLayerVisible(satelliteLayer.getMaplibreMap(), 'ptv-overlays-lez', false);
		    }
		});
	}
	var fullJsonData = JSON.parse(markersDetail);
	var markersDetail = fullJsonData.events;
	var markerArray = [];
	var waypointArray = [];
	for (var index = 0; index < markersDetail.length; index++) {
		var md = markersDetail[index];
		const icon = new L.DivIcon({
			className: 'icon-div',
			html: `<div style="background-color: ` + fullJsonData.color + `; color: ` + fullJsonData.fontColor + `; text-align: center; vertical-align: middle; border-style: solid; border-width: 1px; border-color: ` + fullJsonData.borderColor + `; font-size: 8px;">` + (index + 1) + `</div>`,
			iconSize: [14, 14]
		});
		markerArray[index] = L
			.marker([md.lat, md.lon]).setIcon(icon).bindTooltip(fullJsonData.code + ' - ' + fullJsonData.plate, {
				className: 'leaflet-tooltip'
			}).addTo(monitoringMap);
		waypointArray[index] = L.latLng(md.lat, md.lon);
	}
	// aggiungo singolo marker per il mezzo
	if (!isPoll) {
		if (fullJsonData.tLat != null && fullJsonData.tLon != null) {
			const icon = new L.DivIcon({
				className: 'icon-div',
				html: `<div style="background-color: ` + fullJsonData.color + `; color: ` + fullJsonData.fontColor + `; text-align: center; vertical-align: middle; border-style: solid; border-width: 1px; border-color: ` + fullJsonData.borderColor + `; border-radius: 50px; font-size: 8px;">` + fullJsonData.tIndex + `</div>`,
				iconSize: [14, 14]
			});
			markerArray[index] = L
				.marker([fullJsonData.tLat, fullJsonData.tLon]).setIcon(icon).bindTooltip(fullJsonData.code + ' - ' + fullJsonData.plate, {
					className: 'leaflet-tooltip'
				}).addTo(monitoringMap);
			waypointArray[index] = L.latLng(fullJsonData.tLat, fullJsonData.tLon);
		}
		if (waypointArray != null && waypointArray.length != 0) {
			var bounds = L.latLngBounds(waypointArray);
			monitoringMap.fitBounds(bounds);
		}
	}
}

function findComponentValueFromInput(id_input, index) {
	return document.querySelectorAll("[id$=" + id_input + "]")[index].value;
}

function handleEditArrivalTime(e, rowId, index) {
	if (e.keyCode == 13) {
		editRowArrivalTime([{ name: 'row_id', value: rowId }, { name: 'new_val', value: findComponentValueFromInput('at-input', index) }]);
		jQuery('#update-response-detail-table').click();
		return false;
	}
}

function findComponentValueFromAutocomplete(id_input, index) {
	return document.querySelectorAll("[id$=" + id_input + "]")[index].children[0].value;
}

(function() {
	'use strict';

	var defaultOptions = function(options) {
		if (typeof options === 'number') {
			// Legacy
			options = {
				precision: options
			};
		} else {
			options = options || {};
		}

		options.precision = options.precision || 5;
		options.factor = options.factor || Math.pow(10, options.precision);
		options.dimension = options.dimension || 2;
		return options;
	};

	var PolylineUtil = {
		encode: function(points, options) {
			options = defaultOptions(options);

			var flatPoints = [];
			for (var i = 0, len = points.length; i < len; ++i) {
				var point = points[i];

				if (options.dimension === 2) {
					flatPoints.push(point.lat || point[0]);
					flatPoints.push(point.lng || point[1]);
				} else {
					for (var dim = 0; dim < options.dimension; ++dim) {
						flatPoints.push(point[dim]);
					}
				}
			}

			return this.encodeDeltas(flatPoints, options);
		},

		decode: function(encoded, options) {
			options = defaultOptions(options);

			var flatPoints = this.decodeDeltas(encoded, options);

			var points = [];
			for (var i = 0, len = flatPoints.length; i
				+ (options.dimension - 1) < len;) {
				var point = [];

				for (var dim = 0; dim < options.dimension; ++dim) {
					point.push(flatPoints[i++]);
				}

				points.push(point);
			}

			return points;
		},

		encodeDeltas: function(numbers, options) {
			options = defaultOptions(options);

			var lastNumbers = [];

			for (var i = 0, len = numbers.length; i < len;) {
				for (var d = 0; d < options.dimension; ++d, ++i) {
					var num = numbers[i];
					var delta = num - (lastNumbers[d] || 0);
					lastNumbers[d] = num;

					numbers[i] = delta;
				}
			}

			return this.encodeFloats(numbers, options);
		},

		decodeDeltas: function(encoded, options) {
			options = defaultOptions(options);

			var lastNumbers = [];

			var numbers = this.decodeFloats(encoded, options);
			for (var i = 0, len = numbers.length; i < len;) {
				for (var d = 0; d < options.dimension; ++d, ++i) {
					numbers[i] = Math.round((lastNumbers[d] = numbers[i]
						+ (lastNumbers[d] || 0))
						* options.factor)
						/ options.factor;
				}
			}

			return numbers;
		},

		encodeFloats: function(numbers, options) {
			options = defaultOptions(options);

			for (var i = 0, len = numbers.length; i < len; ++i) {
				numbers[i] = Math.round(numbers[i] * options.factor);
			}

			return this.encodeSignedIntegers(numbers);
		},

		decodeFloats: function(encoded, options) {
			options = defaultOptions(options);

			var numbers = this.decodeSignedIntegers(encoded);
			for (var i = 0, len = numbers.length; i < len; ++i) {
				numbers[i] /= options.factor;
			}

			return numbers;
		},

		encodeSignedIntegers: function(numbers) {
			for (var i = 0, len = numbers.length; i < len; ++i) {
				var num = numbers[i];
				numbers[i] = (num < 0) ? ~(num << 1) : (num << 1);
			}

			return this.encodeUnsignedIntegers(numbers);
		},

		decodeSignedIntegers: function(encoded) {
			var numbers = this.decodeUnsignedIntegers(encoded);

			for (var i = 0, len = numbers.length; i < len; ++i) {
				var num = numbers[i];
				numbers[i] = (num & 1) ? ~(num >> 1) : (num >> 1);
			}

			return numbers;
		},

		encodeUnsignedIntegers: function(numbers) {
			var encoded = '';
			for (var i = 0, len = numbers.length; i < len; ++i) {
				encoded += this.encodeUnsignedInteger(numbers[i]);
			}
			return encoded;
		},

		decodeUnsignedIntegers: function(encoded) {
			var numbers = [];

			var current = 0;
			var shift = 0;

			for (var i = 0, len = encoded.length; i < len; ++i) {
				var b = encoded.charCodeAt(i) - 63;

				current |= (b & 0x1f) << shift;

				if (b < 0x20) {
					numbers.push(current);
					current = 0;
					shift = 0;
				} else {
					shift += 5;
				}
			}

			return numbers;
		},

		encodeSignedInteger: function(num) {
			num = (num < 0) ? ~(num << 1) : (num << 1);
			return this.encodeUnsignedInteger(num);
		},

		// This function is very similar to Google's, but I added
		// some stuff to deal with the double slash issue.
		encodeUnsignedInteger: function(num) {
			var value, encoded = '';
			while (num >= 0x20) {
				value = (0x20 | (num & 0x1f)) + 63;
				encoded += (String.fromCharCode(value));
				num >>= 5;
			}
			value = num + 63;
			encoded += (String.fromCharCode(value));

			return encoded;
		}
	};

	// Export Node module
	if (typeof module === 'object' && typeof module.exports === 'object') {
		module.exports = PolylineUtil;
	}

	// Inject functionality into Leaflet
	if (typeof L === 'object') {
		if (!(L.Polyline.prototype.fromEncoded)) {
			L.Polyline.fromEncoded = function(encoded, options) {
				return L.polyline(PolylineUtil.decode(encoded), options);
			};
		}
		if (!(L.Polygon.prototype.fromEncoded)) {
			L.Polygon.fromEncoded = function(encoded, options) {
				return L.polygon(PolylineUtil.decode(encoded), options);
			};
		}

		var encodeMixin = {
			encodePath: function() {
				return PolylineUtil.encode(this.getLatLngs());
			}
		};

		if (!L.Polyline.prototype.encodePath) {
			L.Polyline.include(encodeMixin);
		}
		if (!L.Polygon.prototype.encodePath) {
			L.Polygon.include(encodeMixin);
		}

		L.PolylineUtil = PolylineUtil;
	}
})();

function hideLastColumn(selector) {
	$(`[id$="${selector}"] .ui-datatable-tablewrapper table`).each(function() {
		$(this).find('tr').each(function() {
			$(this).find('th:last-child, td:last-child').hide();
		});
	});
}

function showLastColumn(selector) {
	$(`[id$="${selector}"] .ui-datatable-tablewrapper table`).each(function() {
		$(this).find('tr').each(function() {
			$(this).find('th:last-child, td:last-child').show();
		});
	});
}

function adjustTableScrollColumns() {
	$('.ui-datatable-scrollable-body').each(function(index, body) {
		var $body = $(body);
		var hasScroll = body.scrollHeight > body.clientHeight;
		if (!hasScroll) {
			$body.closest('.ui-datatable-scrollable')
				.find('.ui-datatable-scrollable-header-box').attr('style', 'margin-right: -1px !important');
			if (index === 0) {
				hideLastColumn('summary-table-totals');
				hideLastColumn('dailyRouteTotalTable');
				hideLastColumn('fcTotalTable');
			}
		} else {
			$body.closest('.ui-datatable-scrollable')
				.find('.ui-datatable-scrollable-header-box').css('margin-right', '');
			if (index === 0) {
				showLastColumn('summary-table-totals');
				showLastColumn('dailyRouteTotalTable');
				showLastColumn('fcTotalTable');
			}
		}
	});
}

function doAdjustItinerariesDialog(dlg) {
	setTimeout(() => {
		const navbar = document.querySelector(".navbar-fixed-top");
		const overlay = document.getElementById("response-detail-form:" + dlg + "_modal");
		const dialog = document.getElementById("response-detail-form:" + dlg);
		const blockUI = document.getElementById("response-detail-form:blockUI");
		let baseZ = 1000;
		if (navbar) {
			const computedZ = window.getComputedStyle(navbar).zIndex;
			baseZ = isNaN(parseInt(computedZ)) ? baseZ : parseInt(computedZ);
		}
		const isChildDialog = dlg !== 'itinerariesDialog';
		const dialogZ = isChildDialog ? baseZ + 4 : baseZ + 2;
		const overlayZ = isChildDialog ? baseZ + 3 : baseZ + 1;
		if (overlay) {
			overlay.style.zIndex = overlayZ.toString();
		}
		if (dialog) {
			dialog.style.zIndex = dialogZ.toString();
			const observer = new MutationObserver(() => {
				const currentZ = parseInt(window.getComputedStyle(dialog).zIndex);
				if (currentZ !== dialogZ) {
					dialog.style.zIndex = dialogZ.toString();
				}
			});
			observer.observe(dialog, { attributes: true, attributeFilter: ['style'] });
			for (const key in PrimeFaces.widgets) {
				const widget = PrimeFaces.widgets[key];
				if (widget && widget.jq && widget.jq.closest("#response-detail-form\\:" + dlg).length > 0 && widget.panel && widget.panel.hasClass("ui-autocomplete-panel") && typeof widget.show === "function") {
					const originalShow = widget.show;
					widget.show = function() {
						originalShow.apply(this, arguments);
						setTimeout(() => {
							if (this.panel) {
								this.panel.css("z-index", dialogZ + 5);
							}
						}, 0);
					};
				}
			}
		}
	}, 100);
}

function doAdjustPrivacyDialog() {
    setTimeout(() => {
        const navbar = document.querySelector(".navbar-fixed-top");
        const overlay = document.querySelector(".ui-widget-overlay");
        const dialog = document.getElementById("privacyDialog");
        let baseZ = 1000;
        if (navbar) {
            const computedZ = window.getComputedStyle(navbar).zIndex;
            baseZ = isNaN(parseInt(computedZ)) ? baseZ : parseInt(computedZ);
        }
        const overlayZ = baseZ + 1;
        const dialogZ = baseZ + 2;
        if (overlay) {
            overlay.style.zIndex = overlayZ.toString();
        }
        if (dialog) {
            dialog.style.zIndex = dialogZ.toString();
            // difesa extra: PrimeFaces potrebbe ritoccare lo style
            const observer = new MutationObserver(() => {
                const currentZ = parseInt(window.getComputedStyle(dialog).zIndex);
                if (currentZ !== dialogZ) {
                    dialog.style.zIndex = dialogZ.toString();
                }
            });
            observer.observe(dialog, {
                attributes: true,
                attributeFilter: ['style']
            });
        }
    }, 100);
}

function doAdjustTableScrollColumns() {
	adjustTableScrollColumns();
	scrollContainer.scrollTop = scrollTop;
}

function initScrollTop() {
	scrollTop = scrollContainer.scrollTop;
}

function startUpload() {
	const widget = PF('importOrders');
	totalFiles = widget.files.length;
	uploadedFiles = 0;
	PF('blockBodyUIWidget').show();
}

function fileUploaded() {
	uploadedFiles++;
	if (uploadedFiles === totalFiles) {
		PF('blockBodyUIWidget').hide();
		PF('importOrdersDlg').hide();
	}
}

function resizeMap() {
	if (itinerariesMap) {
		itinerariesMap.invalidateSize();
	}
}

function patchBlockUI(targetZ) {
	if (blockUIObserver) return;
	const forceZ = () => {
		document.querySelectorAll('.ui-blockui').forEach(el => {
			const current = parseInt(el.style.zIndex);
			if (current < targetZ) {
				el.style.setProperty('z-index', targetZ.toString(), 'important');
			}
		});
	};
	let forceInterval = null;
	const scheduleForce = () => {
		if (forceInterval) clearInterval(forceInterval);
		let count = 0;
		forceInterval = setInterval(() => {
			forceZ();
            count++;
			if (count >= 10) {
				clearInterval(forceInterval);
				forceInterval = null;
			}
		}, 50);
	};
	blockUIObserver = new MutationObserver((mutations) => {
		let needsForce = false;
		for (const m of mutations) {
			if (m.type === 'childList') {
				m.addedNodes.forEach(node => {
					if (node.nodeType === 1) {
						if (node.classList && node.classList.contains('ui-blockui')) needsForce = true;
						if (node.querySelector && node.querySelector('.ui-blockui')) needsForce = true;
					}
				});
			}
			if (m.type === 'attributes' && m.attributeName === 'style') {
				if (m.target.classList && m.target.classList.contains('ui-blockui')) {
					needsForce = true;
				}
			}
		}
		if (needsForce) {
			scheduleForce();
		}
	});
	blockUIObserver.observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ['style'] });
}

$(document).ready(function() {
	$('body').on('keypress', 'input', function(e) {
		if (e.keyCode == 13) {
			return false;
		}
	});
	scrollContainer = document.getElementById('content');
	adjustTableScrollColumns();
	const navbar = document.querySelector(".navbar-fixed-top");
	let baseZ = 1000;
	if (navbar) {
		const computedZ = window.getComputedStyle(navbar).zIndex;
		baseZ = isNaN(parseInt(computedZ)) ? baseZ : parseInt(computedZ);
	}
	patchBlockUI(baseZ + 10);
});